<Window x:Class="MyQuicker.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="750"
        Height="500"
        ResizeMode="NoResize"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Modern sidebar nav item: no radio circle, menu-item look -->
        <Style x:Key="NavRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Nav" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Background="#0066CC"
                                    Opacity="0" />
                            <Border x:Name="Bd" Background="Transparent" Padding="20,0">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBEBEB" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFFFFF" />
                                <Setter Property="Foreground" Value="#0066CC" />
                                <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat blue action button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0066CC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0055AA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bold, light DataGrid column headers -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F7F7" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#EAEAEA" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#F7F7F7" BorderThickness="0,0,1,0" BorderBrush="#EAEAEA">
            <StackPanel>
                <TextBlock Text="⚙ 设置中心" FontSize="18" FontWeight="Bold"
                           Margin="20,20,0,30" Foreground="#333" />
                <RadioButton x:Name="NavGeneral" Content="常规"
                             Style="{StaticResource NavRadioButton}" IsChecked="True" />
                <RadioButton x:Name="NavActions" Content="动作管理"
                             Style="{StaticResource NavRadioButton}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Page 1: General -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding IsChecked, ElementName=NavGeneral, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="常规设置" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20" />
                <TextBlock Text="操作触发参数" FontSize="13" Foreground="#888" Margin="0,0,0,8" />
                <ComboBox x:Name="WakeupKeyCombo" FontSize="14" Padding="10,8"
                          Width="320" HorizontalAlignment="Left" SelectedIndex="0">
                    <ComboBoxItem Content="鼠标中键" />
                    <ComboBoxItem Content="鼠标侧键 1 (后退)" />
                    <ComboBoxItem Content="鼠标侧键 2 (前进)" />
                </ComboBox>
            </StackPanel>

            <!-- Page 2: Actions -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsChecked, ElementName=NavActions, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="动作管理" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20" />
                <DataGrid x:Name="ActionsGrid" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          CanUserResizeColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="#EFEFEF"
                          VerticalGridLinesBrush="#EFEFEF"
                          BorderBrush="#EAEAEA"
                          BorderThickness="1"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          AlternationCount="2"
                          ColumnHeaderHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="命令" Binding="{Binding Command}" Width="2*" />
                        <DataGridTextColumn Header="参数" Binding="{Binding Arguments}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Apply button -->
            <Button Grid.Row="1" Content="应用设置" Style="{StaticResource ActionButton}"
                    Click="SaveButton_Click" HorizontalAlignment="Right" Margin="0,12,0,0" />
        </Grid>
    </Grid>
</Window>
