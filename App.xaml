<Application x:Class="Aurora.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Aurora"
             xmlns:conv="clr-namespace:Aurora.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/ThemeStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:HexToGlyphConverter x:Key="HexToGlyphConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
